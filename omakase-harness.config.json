{
  "competition": "omakase-harness",
  "artifact": "harness/",
  "router_pin": "router-pin.json",
  "eval": {
    "pool_version": "pool.dev@v1",
    "split": "dev",
    "seed": 1,
    "budget": {"max_turns": 5, "max_tokens": 4000},
    "cost_tolerance": 1.15,
    "significance_alpha": 0.05
  },
  "delta_tiers": {
    "breakthrough": {"min_delta": 0.08, "multiplier": 2.0},
    "major-delta": {"min_delta": 0.03, "multiplier": 1.0},
    "minor-delta": {"min_delta": 0.0, "multiplier": 0.3, "note": "still requires paired significance"}
  },
  "gittensor_repo_config": {
    "weight": 0.5,
    "trusted_label_pipeline": true,
    "default_label_multiplier": 0.0,
    "fixed_base_score": 1.0,
    "note": "tier label held king-of-the-hill style until the next merge strips it"
  },
  "miner_limits": {
    "prs_per_24h_per_hotkey": 1,
    "open_prs_per_hotkey": 1,
    "new_pr_resets_cooldown": true,
    "credibility_floor_for_banlist": 0.1
  },
  "dependency_policy": "requirements.lock is locked; new dependencies require a maintainer-gated manifest change",
  "reset_window": "monday 00:00 UTC"
}
